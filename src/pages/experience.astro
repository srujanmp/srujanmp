---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content'; // <-- Add 'render' here

const allExperience = await getCollection('experience');
---

<Layout title="Experience | Srujan M Padmashali">
  <h1 class="text-2xl font-bold uppercase tracking-wider mb-8">Experience</h1>

  <div class="flex flex-col gap-10">
    {allExperience.map(async (exp) => {
      const { Content } = await render(exp); // <-- Change this line
      return (
        <article>
          <div class="flex justify-between items-baseline border-b border-zinc-300 dark:border-zinc-700 pb-2 mb-4">
            <div>
              <h2 class="font-bold text-lg">{exp.data.role}</h2>
              <p class="text-sm text-zinc-600 dark:text-zinc-400">{exp.data.company} — {exp.data.location}</p>
            </div>
            <span class="text-xs whitespace-nowrap">{exp.data.date}</span>
          </div>
          <div class="prose prose-sm dark:prose-invert max-w-none marker:text-zinc-900 dark:marker:text-zinc-100">
            <Content />
          </div>
        </article>
      );
    })}
  </div>
</Layout>