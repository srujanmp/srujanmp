---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1);
---
<div class="flex justify-between items-center border-b border-zinc-300 dark:border-zinc-700 pb-4 mb-8">
  <nav class="flex gap-6">
    <a href="/" class={`hover:underline ${currentPath === '' ? 'font-bold' : ''}`}>Profile</a>
    <a href="/experience" class={`hover:underline ${currentPath === 'experience' ? 'font-bold' : ''}`}>Experience</a>
    <a href="/projects" class={`hover:underline ${currentPath === 'projects' ? 'font-bold' : ''}`}>Projects</a>
  </nav>

  <button id="theme-toggle" class="px-3 py-1 border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-200 dark:hover:bg-zinc-800 transition-colors text-lg">
    <span id="theme-icon">󰖨</span> </button>
</div>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("dark");

    const isDark = element.classList.contains("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");

    const icon = document.getElementById("theme-icon");
    if(icon) {
      icon.innerText = isDark ? "󰖔" : "󰖨"; // Switch between Moon 󰖔 and Sun 󰖨
    }
  }

  document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);

  // Set initial icon on load
  if (document.documentElement.classList.contains("dark")) {
    const icon = document.getElementById("theme-icon");
    if(icon) icon.innerText = "󰖔";
  }
</script>