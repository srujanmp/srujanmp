---
const navItems = [
  { href: '/', key: '', label: 'Profile' },
  { href: '/experience', key: 'experience', label: 'Experience' },
  { href: '/projects', key: 'projects', label: 'Projects' },
  { href: '/blog', key: 'blog', label: 'Blog' },
];
const navLinkBaseClass =
  "relative inline-block pb-1 after:content-[''] after:absolute after:left-0 after:-bottom-0.5 after:h-[2px] after:w-full after:bg-current after:origin-center after:transition-transform after:duration-300 after:ease-out";
---
<div class="border-b border-zinc-300 dark:border-zinc-700 pb-4 mb-8">
  <div class="flex justify-between items-center gap-3">
    <nav class="hidden md:flex gap-8">
      {navItems.map((item) => (
        <a href={item.href} data-astro-prefetch="hover" data-nav-key={item.key} class={`${navLinkBaseClass} after:scale-x-0 hover:after:scale-x-100`}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="md:hidden flex-1 relative" id="mobile-tab-switcher">
      <button
        id="mobile-tab-toggle"
        type="button"
        aria-haspopup="menu"
        aria-expanded="false"
        class="w-full h-11 rounded-md border border-zinc-300 dark:border-zinc-700 bg-transparent px-3 text-base flex items-center justify-between"
      >
        <span>Profile</span>
        <span aria-hidden="true">▾</span>
      </button>
      <div
        id="mobile-tab-menu"
        role="menu"
        class="hidden absolute top-full mt-2 left-0 right-0 rounded-md border border-zinc-300 dark:border-zinc-700 bg-[#f8ecd2]/95 dark:bg-zinc-900/95 backdrop-blur-sm shadow-lg overflow-hidden z-50"
      >
        {navItems.map((item) => (
          <a
            href={item.href}
            data-astro-prefetch="hover"
            data-nav-key={item.key}
            data-nav-label={item.label}
            role="menuitem"
            class="block px-3 py-2 text-base border-b border-zinc-300/70 dark:border-zinc-700/70 last:border-b-0 hover:bg-zinc-200/50 dark:hover:bg-zinc-800/60"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div class="flex items-center gap-3 md:gap-6 shrink-0">
      <a href="https://github.com/srujanmp" target="_blank" rel="noopener noreferrer" class="hover:text-zinc-500 transition-colors flex items-center" aria-label="GitHub">
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8" aria-hidden="true">
        <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-2.08c-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.17 1.75 1.17 1.02 1.75 2.67 1.24 3.32.95.1-.74.4-1.24.72-1.53-2.55-.29-5.23-1.27-5.23-5.65 0-1.25.45-2.27 1.17-3.07-.12-.29-.5-1.45.11-3.03 0 0 .96-.31 3.15 1.17a10.9 10.9 0 0 1 5.73 0c2.18-1.48 3.14-1.17 3.14-1.17.62 1.58.24 2.74.12 3.03.73.8 1.16 1.82 1.16 3.07 0 4.39-2.68 5.36-5.24 5.64.42.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/>
      </svg>
      </a>

      <button id="theme-toggle" class="flex items-center justify-center w-11 h-11 md:w-12 md:h-12 border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-200 dark:hover:bg-zinc-800 transition-colors rounded text-2xl cursor-pointer">
        <span id="theme-icon" class="leading-none">☀</span>
      </button>
    </div>
  </div>

  <script is:inline>
    const updateNavActive = () => {
      const currentPath = window.location.pathname.slice(1);

      // Update desktop nav links
      document.querySelectorAll('nav a[data-nav-key]').forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        const key = link.dataset.navKey ?? '';
        const isActive = key === currentPath;
        link.classList.toggle('after:scale-x-100', isActive);
        link.classList.toggle('after:scale-x-0', !isActive);
        link.classList.toggle('hover:after:scale-x-100', !isActive);
      });

      // Update mobile menu links
      const mobileMenu = document.getElementById('mobile-tab-menu');
      if (mobileMenu instanceof HTMLElement) {
        var activeLabel = 'Profile';
        mobileMenu.querySelectorAll('a[data-nav-key]').forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) return;
          const key = link.dataset.navKey ?? '';
          const isActive = key === currentPath;
          link.classList.toggle('font-bold', isActive);
          link.classList.toggle('bg-zinc-200/60', isActive);
          link.classList.toggle('dark:bg-zinc-800/70', isActive);
          link.classList.toggle('hover:bg-zinc-200/50', !isActive);
          link.classList.toggle('dark:hover:bg-zinc-800/60', !isActive);
          if (isActive) activeLabel = link.dataset.navLabel ?? 'Profile';
        });

        // Update mobile toggle button label
        const toggleSpan = document.querySelector('#mobile-tab-toggle span:first-child');
        if (toggleSpan instanceof HTMLElement) toggleSpan.textContent = activeLabel;

        // Close mobile menu after navigation
        mobileMenu.classList.add('hidden');
        const toggle = document.getElementById('mobile-tab-toggle');
        if (toggle instanceof HTMLButtonElement) toggle.setAttribute('aria-expanded', 'false');
      }
    };

    if (!window.__navActiveHandlerBound) {
      window.__navActiveHandlerBound = true;
      document.addEventListener('astro:after-swap', updateNavActive);
      document.addEventListener('DOMContentLoaded', updateNavActive);
    }
  </script>

  <script is:inline>
    const setupMobileTabSwitch = () => {
      const wrapper = document.getElementById('mobile-tab-switcher');
      const toggle = document.getElementById('mobile-tab-toggle');
      const menu = document.getElementById('mobile-tab-menu');

      if (!(wrapper instanceof HTMLElement)) return;
      if (!(toggle instanceof HTMLButtonElement)) return;
      if (!(menu instanceof HTMLElement)) return;
      if (wrapper.dataset.bound === 'true') return;

      const closeMenu = () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
      };

      const openMenu = () => {
        menu.classList.remove('hidden');
        toggle.setAttribute('aria-expanded', 'true');
      };

      toggle.addEventListener('click', () => {
        const isOpen = !menu.classList.contains('hidden');
        if (isOpen) {
          closeMenu();
          return;
        }

        openMenu();
      });

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Element)) return;
        if (wrapper.contains(event.target)) return;
        closeMenu();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') closeMenu();
      });

      wrapper.dataset.bound = 'true';
    };

    document.addEventListener('DOMContentLoaded', setupMobileTabSwitch);
    document.addEventListener('astro:page-load', setupMobileTabSwitch);
  </script>
</div>