---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <script>
      // Check local storage or system preference to set initial theme
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="bg-[#FDF8F5] dark:bg-[#1A1A1A] text-zinc-900 dark:text-zinc-100 font-['3270NerdFont'] antialiased min-h-screen transition-colors duration-300">
    <main class="w-[80%] mx-auto py-12">
      <Navbar />
      <slot />
    </main>
  </body>
</html>